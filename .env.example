ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# Optional. Self-consistency samples per doc (confidence signal, not an accuracy
# lever). Default 3; the public demo runs at 1 (~3x cheaper/snappier).
# N_SAMPLES=1

# Optional. Comma-separated browser origins allowed to call the API (CORS).
# Default is localhost for dev; set to your UI's deployed origin in prod.
# ALLOWED_ORIGINS=https://your-ui.vercel.app
